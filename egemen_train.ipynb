   "source": [
    "## 8 · Test — Generate Turkish Text"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def generate(prompt: str, max_new_tokens: int = 150, temperature: float = 0.8):\n",
    "    ids = [BOS_ID] + tokenizer.encode(prompt).ids\n",
    "    idx = torch.tensor([ids], dtype=torch.long, device=DEVICE)\n",
    "    out = model.generate(idx, max_new_tokens=max_new_tokens, temperature=temperature)\n",
    "    return tokenizer.decode(out[0].tolist()[len(ids):])\n",
    "\n",
    "prompts = [\n",
    "    \"Türkiye'nin başkenti\",\n",
    "    \"Atatürk, 1923 yılında\",\n",
    "    \"İstanbul Boğazı\",\n",
    "]\n",
    "\n",
    "for p in prompts:\n",
    "    print(f\"Prompt : {p}\")\n",
    "    print(f\"Egemen : {p}{generate(p)}\")\n",
    "    print(\"-\" * 60)"
   ]
  },
