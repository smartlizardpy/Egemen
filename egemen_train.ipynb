   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2 · Config"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from dataclasses import dataclass\n",
    "\n",
    "@dataclass\n",
    "class EgemenConfig:\n",
    "    # ── architecture ──────────────────────────────────\n",
    "    vocab_size:   int   = 32_000\n",
    "    n_layers:     int   = 12\n",
    "    n_heads:      int   = 12\n",
    "    d_model:      int   = 768\n",
    "    # d_ff is computed as 8/3 * d_model, rounded to multiple of 256 (SwiGLU convention)\n",
    "    max_seq_len:  int   = 1024\n",
    "    dropout:      float = 0.1\n",
    "    bias:         bool  = False   # modern LLMs skip biases\n",
    "\n",
    "    # ── training ──────────────────────────────────────\n",
    "    batch_size:      int   = 8\n",
    "    grad_accum:      int   = 4     # effective batch = 32\n",
    "    learning_rate:   float = 3e-4\n",
    "    weight_decay:    float = 0.1\n",
    "    grad_clip:       float = 1.0\n",
    "    num_epochs:      int   = 3\n",
    "    warmup_steps:    int   = 1000\n",
    "    eval_interval:   int   = 500\n",
    "    save_interval:   int   = 1000\n",
    "    log_interval:    int   = 10\n",
    "\n",
    "    # ── tokenizer ──────────────────────────────────────\n",
    "    tokenizer_vocab_size: int = 32_000\n",
    "\n",
    "    # ── paths ──────────────────────────────────────────\n",
    "    tokenizer_path: str = \"./egemen-tokenizer\"\n",
    "    checkpoint_dir: str = \"./egemen-checkpoints\"\n",
    "    hf_repo:        str = \"smartlizardpy/egemen\"  # set to None to skip upload\n",
    "\n",
    "    @property\n",
    "    def d_ff(self) -> int:\n",
    "        raw = int(8 / 3 * self.d_model)\n",
    "        return (raw + 255) // 256 * 256\n",
    "\n",
    "    @property\n",
    "    def head_dim(self) -> int:\n",
    "        return self.d_model // self.n_heads\n",
    "\n",
    "cfg = EgemenConfig()\n",
    "\n",
    "# Estimate parameter count\n",
    "embed   = cfg.vocab_size * cfg.d_model\n",
    "attn    = cfg.n_layers * 4 * cfg.d_model * cfg.d_model\n",
    "ff      = cfg.n_layers * 3 * cfg.d_model * cfg.d_ff\n",
    "norms   = cfg.n_layers * 2 * cfg.d_model\n",
    "total   = embed + attn + ff + norms\n",
    "print(f\"Egemen-Small: ~{total/1e6:.0f}M parameters\")\n",
    "print(f\"d_ff = {cfg.d_ff} | head_dim = {cfg.head_dim}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3 · Fetch Training Data from GitHub"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests, os, io\n",
    "from pathlib import Path\n",
    "from tqdm.auto import tqdm\n",
    "\n",
    "RAW = \"https://raw.githubusercontent.com/smartlizardpy/Egemen/main\"\n",
    "API = \"https://api.github.com/repos/smartlizardpy/Egemen/git/trees/main?recursive=1\"\n",
    "\n",
    "os.makedirs(\"data\", exist_ok=True)\n",
    "\n",
    "def download(url: str, dest: str):\n",
    "    if Path(dest).exists():\n",
    "        print(f\"  Already exists: {dest}\")\n",
    "        return\n",
    "    r = requests.get(url, timeout=60)\n",
    "    r.raise_for_status()\n",
    "    Path(dest).write_bytes(r.content)\n",
    "\n",
    "# people.txt\n",
    "print(\"Downloading people.txt...\")\n",
    "download(f\"{RAW}/scraper/data/people.txt\", \"data/people.txt\")\n",
    "\n",
    "# news articles\n",
    "print(\"Fetching news file list...\")\n",
    "tree = requests.get(API, timeout=30).json()\n",
    "news_paths = [\n",
    "    item[\"path\"] for item in tree.get(\"tree\", [])\n",
    "    if item[\"path\"].startswith(\"scraper/data/news/\") and item[\"path\"].endswith(\".txt\")\n",
    "]\n",
    "print(f\"Found {len(news_paths)} news files — downloading...\")\n",
    "\n",
    "os.makedirs(\"data/news\", exist_ok=True)\n",
    "for path in tqdm(news_paths):\n",
    "    fname = path.replace(\"/\", \"_\")\n",
    "    download(f\"{RAW}/{path}\", f\"data/news/{fname}\")\n",
    "\n",
    "print(\"Done.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4 · Train the Turkish BPE Tokenizer"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from tokenizers import Tokenizer, models, trainers, pre_tokenizers, decoders, normalizers\n",
    "from pathlib import Path\n",
    "\n",
    "def iter_training_texts():\n",
    "    \"\"\"Yield raw text strings for tokenizer training.\"\"\"\n",
    "    for path in Path(\"data\").rglob(\"*.txt\"):\n",
    "        text = path.read_text(encoding=\"utf-8\", errors=\"ignore\")\n",
    "        # strip SOURCE: headers from news files\n",
    "        if text.startswith(\"SOURCE:\"):\n",
    "            text = text.split(\"\\n\\n\", 1)[-1]\n",
    "        # strip === headers from people.txt\n",
    "        text = \"\\n\".join(\n",
    "            line for line in text.splitlines()\n",
    "            if not line.startswith(\"===\") and not line.startswith(\"---\")\n",
    "        )\n",
    "        if len(text.strip()) > 50:\n",
    "            yield text\n",
    "\n",
    "if Path(cfg.tokenizer_path).exists():\n",
    "    print(f\"Tokenizer already trained at {cfg.tokenizer_path}\")\n",
    "else:\n",
    "    print(f\"Training BPE tokenizer (vocab={cfg.tokenizer_vocab_size})...\")\n",
    "\n",
    "    tokenizer = Tokenizer(models.BPE(unk_token=\"<unk>\"))\n",
    "    tokenizer.normalizer = normalizers.NFKC()\n",
    "    tokenizer.pre_tokenizer = pre_tokenizers.ByteLevel(add_prefix_space=False)\n",
    "    tokenizer.decoder = decoders.ByteLevel()\n",
    "\n",
    "    special_tokens = [\"<unk>\", \"<s>\", \"</s>\", \"<pad>\", \"<mask>\"]\n",
    "    trainer = trainers.BpeTrainer(\n",
    "        vocab_size=cfg.tokenizer_vocab_size,\n",
    "        special_tokens=special_tokens,\n",
    "        min_frequency=2,\n",
    "        show_progress=True,\n",
    "    )\n",
    "\n",
    "    tokenizer.train_from_iterator(iter_training_texts(), trainer=trainer)\n",
    "    tokenizer.save(cfg.tokenizer_path + \"/tokenizer.json\")\n",
    "    os.makedirs(cfg.tokenizer_path, exist_ok=True)\n",
    "    tokenizer.save(cfg.tokenizer_path + \"/tokenizer.json\")\n",
    "    print(f\"Saved to {cfg.tokenizer_path}\")\n",
    "\n",
    "# Load and test\n",
    "tokenizer = Tokenizer.from_file(cfg.tokenizer_path + \"/tokenizer.json\")\n",
    "BOS_ID = tokenizer.token_to_id(\"<s>\")\n",
    "EOS_ID = tokenizer.token_to_id(\"</s>\")\n",
    "PAD_ID = tokenizer.token_to_id(\"<pad>\")\n",
    "\n",
    "test = \"Türkiye'nin başkenti Ankara'dır.\"\n",
    "enc  = tokenizer.encode(test)\n",
    "print(f\"Test: {test}\")\n",
    "print(f\"Tokens: {enc.tokens}\")\n",
    "print(f\"IDs: {enc.ids}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5 · Dataset & DataLoader"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import numpy as np\n",
    "from torch.utils.data import Dataset, DataLoader\n",
    "from pathlib import Path\n",
    "\n",
    "CACHE_FILE = \"data/tokens.bin\"\n",
    "\n",
    "if Path(CACHE_FILE).exists():\n",
    "    print(f\"Loading cached token array from {CACHE_FILE}\")\n",
    "    token_array = np.fromfile(CACHE_FILE, dtype=np.uint16)\n",
    "else:\n",
    "    print(\"Tokenizing all text files (one-time, ~5-10 min)...\")\n",
    "    all_ids = []\n",
    "    files   = list(Path(\"data\").rglob(\"*.txt\"))\n",
    "\n",
    "    for path in tqdm(files):\n",
    "        text = path.read_text(encoding=\"utf-8\", errors=\"ignore\")\n",
    "        if text.startswith(\"SOURCE:\"):\n",
    "            text = text.split(\"\\n\\n\", 1)[-1]\n",
    "        text = \"\\n\".join(\n",
    "            line for line in text.splitlines()\n",
    "            if not line.startswith(\"===\") and not line.startswith(\"---\")\n",
    "        ).strip()\n",
    "        if len(text) < 50:\n",
    "            continue\n",
    "        ids = [BOS_ID] + tokenizer.encode(text).ids + [EOS_ID]\n",
    "        all_ids.extend(ids)\n",
    "\n",
    "    token_array = np.array(all_ids, dtype=np.uint16)\n",
    "    token_array.tofile(CACHE_FILE)\n",
    "    print(f\"Saved {len(token_array):,} tokens to {CACHE_FILE}\")\n",
    "\n",
    "print(f\"Total tokens: {len(token_array):,} ({len(token_array)/1e6:.1f}M)\")\n",
    "\n",
    "# 98% train / 2% val split\n",
    "split      = int(len(token_array) * 0.98)\n",
    "train_data = token_array[:split]\n",
    "val_data   = token_array[split:]\n",
    "print(f\"Train: {len(train_data):,} | Val: {len(val_data):,}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class TokenDataset(Dataset):\n",
    "    def __init__(self, data: np.ndarray, seq_len: int):\n",
    "        self.data    = data\n",
    "        self.seq_len = seq_len\n",
    "\n",
    "    def __len__(self):\n",
    "        return (len(self.data) - 1) // self.seq_len\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        start = idx * self.seq_len\n",
    "        chunk = self.data[start : start + self.seq_len + 1]\n",
    "        x = torch.from_numpy(chunk[:-1].astype(np.int64))\n",
    "        y = torch.from_numpy(chunk[1:].astype(np.int64))\n",
    "        return x, y\n",
    "\n",
    "train_ds = TokenDataset(train_data, cfg.max_seq_len)\n",
    "val_ds   = TokenDataset(val_data,   cfg.max_seq_len)\n",
    "\n",
    "train_loader = DataLoader(train_ds, batch_size=cfg.batch_size, shuffle=True,\n",
    "                          num_workers=2, pin_memory=True, drop_last=True)\n",
    "val_loader   = DataLoader(val_ds,   batch_size=cfg.batch_size, shuffle=False,\n",
    "                          num_workers=2, pin_memory=True, drop_last=True)\n",
    "\n",
    "print(f\"Train batches: {len(train_loader):,} | Val batches: {len(val_loader):,}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6 · Model Architecture"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "import math\n",
    "\n",
    "# ── RMSNorm ───────────────────────────────────────────────────────────────────\n",
    "class RMSNorm(nn.Module):\n",
    "    def __init__(self, d_model: int, eps: float = 1e-6):\n",
    "        super().__init__()\n",
    "        self.weight = nn.Parameter(torch.ones(d_model))\n",
    "        self.eps    = eps\n",
    "\n",
    "    def forward(self, x):\n",
    "        rms = x.pow(2).mean(-1, keepdim=True).add(self.eps).sqrt()\n",
    "        return self.weight * (x / rms)\n",
    "\n",
    "\n",
    "# ── Rotary Position Embeddings (RoPE) ─────────────────────────────────────────\n",
    "class RotaryEmbedding(nn.Module):\n",
    "    def __init__(self, head_dim: int, max_seq_len: int = 4096, base: int = 10_000):\n",
    "        super().__init__()\n",
    "        inv_freq = 1.0 / (base ** (torch.arange(0, head_dim, 2).float() / head_dim))\n",
    "        self.register_buffer(\"inv_freq\", inv_freq, persistent=False)\n",
    "        self._build_cache(max_seq_len)\n",
    "\n",
    "    def _build_cache(self, seq_len: int):\n",
    "        t     = torch.arange(seq_len, device=self.inv_freq.device).float()\n",
    "        freqs = torch.outer(t, self.inv_freq)        # (seq, head_dim/2)\n",
    "        emb   = torch.cat([freqs, freqs], dim=-1)    # (seq, head_dim)\n",
    "        self.register_buffer(\"cos_cache\", emb.cos()[None, None, :, :], persistent=False)\n",
    "        self.register_buffer(\"sin_cache\", emb.sin()[None, None, :, :], persistent=False)\n",
    "\n",
    "    @staticmethod\n",
    "    def _rotate_half(x):\n",
    "        half = x.shape[-1] // 2\n",
    "        return torch.cat([-x[..., half:], x[..., :half]], dim=-1)\n",
    "\n",
    "    def forward(self, q, k):\n",
    "        seq = q.shape[2]\n",
    "        cos = self.cos_cache[:, :, :seq, :]\n",
    "        sin = self.sin_cache[:, :, :seq, :]\n",
    "        q   = (q * cos) + (self._rotate_half(q) * sin)\n",
    "        k   = (k * cos) + (self._rotate_half(k) * sin)\n",
    "        return q, k\n",
    "\n",
    "\n",
    "# ── Causal Multi-Head Attention ───────────────────────────────────────────────\n",
    "class CausalSelfAttention(nn.Module):\n",
    "    def __init__(self, cfg: EgemenConfig):\n",
    "        super().__init__()\n",
    "        assert cfg.d_model % cfg.n_heads == 0\n",
    "        self.n_heads  = cfg.n_heads\n",
    "        self.head_dim = cfg.head_dim\n",
    "        self.scale    = self.head_dim ** -0.5\n",
    "\n",
    "        self.qkv  = nn.Linear(cfg.d_model, 3 * cfg.d_model, bias=cfg.bias)\n",
    "        self.proj = nn.Linear(cfg.d_model, cfg.d_model,     bias=cfg.bias)\n",
    "        self.drop = nn.Dropout(cfg.dropout)\n",
    "        self.rope  = RotaryEmbedding(self.head_dim, cfg.max_seq_len)\n",
    "\n",
    "    def forward(self, x):\n",
    "        B, T, C = x.shape\n",
    "        qkv = self.qkv(x).split(C, dim=-1)\n",
    "        q, k, v = [t.view(B, T, self.n_heads, self.head_dim).transpose(1, 2)\n",
    "                   for t in qkv]                         # (B, H, T, head_dim)\n",
    "\n",
    "        q, k = self.rope(q, k)\n",
    "\n",
    "        # Flash Attention when available, manual causal mask otherwise\n",
    "        if hasattr(F, \"scaled_dot_product_attention\"):\n",
    "            y = F.scaled_dot_product_attention(q, k, v, dropout_p=self.drop.p if self.training else 0.0,\n",
    "                                               is_causal=True)\n",
    "        else:\n",
    "            att = (q @ k.transpose(-2, -1)) * self.scale\n",
    "            mask = torch.tril(torch.ones(T, T, device=x.device)).view(1, 1, T, T)\n",
    "            att  = att.masked_fill(mask == 0, float('-inf'))\n",
    "            att  = self.drop(F.softmax(att, dim=-1))\n",
    "            y    = att @ v\n",
    "\n",
    "        y = y.transpose(1, 2).contiguous().view(B, T, C)\n",
    "        return self.proj(y)\n",
    "\n",
    "\n",
    "# ── SwiGLU Feed-Forward ───────────────────────────────────────────────────────\n",
    "class SwiGLU(nn.Module):\n",
    "    def __init__(self, cfg: EgemenConfig):\n",
    "        super().__init__()\n",
    "        self.gate = nn.Linear(cfg.d_model, cfg.d_ff, bias=cfg.bias)\n",
    "        self.up   = nn.Linear(cfg.d_model, cfg.d_ff, bias=cfg.bias)\n",
    "        self.down = nn.Linear(cfg.d_ff,   cfg.d_model, bias=cfg.bias)\n",
    "        self.drop = nn.Dropout(cfg.dropout)\n",
    "\n",
    "    def forward(self, x):\n",
    "        return self.drop(self.down(F.silu(self.gate(x)) * self.up(x)))\n",
    "\n",
    "\n",
    "# ── Transformer Block ─────────────────────────────────────────────────────────\n",
    "class EgemenBlock(nn.Module):\n",
    "    def __init__(self, cfg: EgemenConfig):\n",
    "        super().__init__()\n",
    "        self.norm1 = RMSNorm(cfg.d_model)\n",
    "        self.attn  = CausalSelfAttention(cfg)\n",
    "        self.norm2 = RMSNorm(cfg.d_model)\n",
    "        self.ff    = SwiGLU(cfg)\n",
    "\n",
    "    def forward(self, x):\n",
    "        x = x + self.attn(self.norm1(x))   # pre-norm residual\n",
    "        x = x + self.ff(self.norm2(x))\n",
    "        return x\n",
    "\n",
    "\n",
    "# ── Egemen Model ──────────────────────────────────────────────────────────────\n",
    "class Egemen(nn.Module):\n",
    "    def __init__(self, cfg: EgemenConfig):\n",
    "        super().__init__()\n",
    "        self.cfg = cfg\n",
    "        self.embed   = nn.Embedding(cfg.vocab_size, cfg.d_model)\n",
    "        self.drop    = nn.Dropout(cfg.dropout)\n",
    "        self.blocks  = nn.ModuleList([EgemenBlock(cfg) for _ in range(cfg.n_layers)])\n",
    "        self.norm    = RMSNorm(cfg.d_model)\n",
    "        self.lm_head = nn.Linear(cfg.d_model, cfg.vocab_size, bias=False)\n",
    "\n",
    "        # weight tying: embed and lm_head share weights (reduces params ~20M)\n",
    "        self.lm_head.weight = self.embed.weight\n",
    "\n",
    "        # init weights\n",
    "        self.apply(self._init_weights)\n",
    "\n",
    "    def _init_weights(self, module):\n",
    "        if isinstance(module, nn.Linear):\n",
    "            nn.init.normal_(module.weight, std=0.02)\n",
    "            if module.bias is not None:\n",
    "                nn.init.zeros_(module.bias)\n",
    "        elif isinstance(module, nn.Embedding):\n",
    "            nn.init.normal_(module.weight, std=0.02)\n",
    "\n",
    "    def forward(self, x, targets=None):\n",
    "        x   = self.drop(self.embed(x))\n",
    "        for block in self.blocks:\n",
    "            x = block(x)\n",
    "        x   = self.norm(x)\n",
    "        logits = self.lm_head(x)\n",
    "\n",
    "        loss = None\n",
    "        if targets is not None:\n",
    "            loss = F.cross_entropy(logits.view(-1, self.cfg.vocab_size),\n",
    "                                   targets.view(-1), ignore_index=PAD_ID)\n",
    "        return logits, loss\n",
    "\n",
    "    @torch.no_grad()\n",
    "    def generate(self, idx, max_new_tokens: int, temperature: float = 0.8,\n",
    "                 top_k: int = 50, top_p: float = 0.9):\n",
    "        self.eval()\n",
    "        for _ in range(max_new_tokens):\n",
    "            ctx     = idx[:, -self.cfg.max_seq_len:]\n",
    "            logits, _ = self(ctx)\n",
    "            logits  = logits[:, -1, :] / temperature\n",
    "\n",
    "            # top-k\n",
    "            if top_k:\n",
    "                v, _ = torch.topk(logits, min(top_k, logits.size(-1)))\n",
    "                logits[logits < v[:, [-1]]] = float('-inf')\n",
    "\n",
    "            # top-p (nucleus)\n",
    "            if top_p < 1.0:\n",
    "                sorted_logits, sorted_idx = torch.sort(logits, descending=True)\n",
    "                cum_probs = sorted_logits.softmax(-1).cumsum(-1)\n",
    "                remove    = cum_probs - sorted_logits.softmax(-1) > top_p\n",
    "                sorted_logits[remove] = float('-inf')\n",
    "                logits = sorted_logits.scatter(1, sorted_idx, sorted_logits)\n",
    "\n",
    "            next_tok = torch.multinomial(logits.softmax(-1), num_samples=1)\n",
    "            idx      = torch.cat([idx, next_tok], dim=1)\n",
    "            if next_tok.item() == EOS_ID:\n",
    "                break\n",
    "        return idx\n",
    "\n",
    "    def num_params(self) -> int:\n",
    "        return sum(p.numel() for p in self.parameters())\n",
    "\n",
    "\n",
    "DEVICE = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "model  = Egemen(cfg).to(DEVICE)\n",
    "print(f\"Egemen | {model.num_params()/1e6:.1f}M params | device: {DEVICE}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7 · Training Loop"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, math, time\n",
    "from pathlib import Path\n",
    "\n",
    "os.makedirs(cfg.checkpoint_dir, exist_ok=True)\n",
    "\n",
    "# ── Optimizer ──────────────────────────────────────────────────────────────────\n",
    "# Separate weight decay: apply to matrices, not norms/biases/embeddings\n",
    "decay_params   = [p for n, p in model.named_parameters() if p.ndim >= 2]\n",
    "nodecay_params = [p for n, p in model.named_parameters() if p.ndim < 2]\n",
    "optimizer = torch.optim.AdamW(\n",
    "    [{\"params\": decay_params,   \"weight_decay\": cfg.weight_decay},\n",
    "     {\"params\": nodecay_params, \"weight_decay\": 0.0}],\n",
    "    lr=cfg.learning_rate, betas=(0.9, 0.95), eps=1e-8,\n",
    "    fused=True if DEVICE.type == \"cuda\" else False,\n",
    ")\n",
    "\n",
    "# ── LR Schedule: linear warmup → cosine decay ──────────────────────────────────\n",
    "total_steps = len(train_loader) * cfg.num_epochs // cfg.grad_accum\n",
    "\n",
    "def get_lr(step: int) -> float:\n",
    "    if step < cfg.warmup_steps:\n",
    "        return cfg.learning_rate * step / cfg.warmup_steps\n",
    "    ratio = (step - cfg.warmup_steps) / max(1, total_steps - cfg.warmup_steps)\n",
    "    return cfg.learning_rate * 0.5 * (1.0 + math.cos(math.pi * ratio))\n",
    "\n",
    "# ── Resume from checkpoint if available ────────────────────────────────────────\n",
    "start_epoch = 0\n",
    "global_step = 0\n",
    "checkpoints = sorted(Path(cfg.checkpoint_dir).glob(\"step-*.pt\"))\n",
    "if checkpoints:\n",
    "    ckpt = torch.load(checkpoints[-1], map_location=DEVICE)\n",
    "    model.load_state_dict(ckpt[\"model\"])\n",
    "    optimizer.load_state_dict(ckpt[\"optimizer\"])\n",
    "    start_epoch = ckpt[\"epoch\"]\n",
    "    global_step = ckpt[\"step\"]\n",
    "    print(f\"Resumed from {checkpoints[-1]} (epoch {start_epoch}, step {global_step})\")\n",
    "\n",
    "scaler = torch.cuda.amp.GradScaler(enabled=(DEVICE.type == \"cuda\"))\n",
    "\n",
    "print(f\"Training for {cfg.num_epochs} epochs | {total_steps:,} optimizer steps\")\n",
    "print(f\"LR: {cfg.learning_rate} | batch: {cfg.batch_size * cfg.grad_accum} tokens × {cfg.max_seq_len}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@torch.no_grad()\n",
    "def evaluate():\n",
    "    model.eval()\n",
    "    losses = []\n",
    "    for i, (x, y) in enumerate(val_loader):\n",
    "        if i >= 50: break   # 50 batches is enough for a stable estimate\n",
    "        x, y = x.to(DEVICE), y.to(DEVICE)\n",
    "        with torch.autocast(device_type=DEVICE.type, dtype=torch.bfloat16):\n",
    "            _, loss = model(x, y)\n",
    "        losses.append(loss.item())\n",
    "    model.train()\n",
    "    return sum(losses) / len(losses)\n",
    "\n",
    "\n",
    "def save_checkpoint(epoch: int, step: int):\n",
    "    path = f\"{cfg.checkpoint_dir}/step-{step:07d}.pt\"\n",
    "    torch.save({\"model\": model.state_dict(),\n",
    "                \"optimizer\": optimizer.state_dict(),\n",
    "                \"epoch\": epoch, \"step\": step}, path)\n",
    "    # keep only last 3 checkpoints\n",
    "    old = sorted(Path(cfg.checkpoint_dir).glob(\"step-*.pt\"))[:-3]\n",
    "    for f in old: f.unlink()\n",
    "    print(f\"  Checkpoint saved: {path}\")\n",
    "\n",
    "\n",
    "# ── Main training loop ────────────────────────────────────────────────────────\n",
    "model.train()\n",
    "t0 = time.time()\n",
    "\n",
    "for epoch in range(start_epoch, cfg.num_epochs):\n",
    "    optimizer.zero_grad()\n",
    "\n",
    "    for local_step, (x, y) in enumerate(train_loader):\n",
    "        x, y = x.to(DEVICE, non_blocking=True), y.to(DEVICE, non_blocking=True)\n",
    "\n",
    "        with torch.autocast(device_type=DEVICE.type, dtype=torch.bfloat16):\n",
    "            _, loss = model(x, y)\n",
    "            loss    = loss / cfg.grad_accum\n",
    "\n",
    "        scaler.scale(loss).backward()\n",
    "\n",
    "        if (local_step + 1) % cfg.grad_accum == 0:\n",
    "            scaler.unscale_(optimizer)\n",
    "            torch.nn.utils.clip_grad_norm_(model.parameters(), cfg.grad_clip)\n",
    "\n",
    "            # update lr\n",
    "            lr = get_lr(global_step)\n",
    "            for pg in optimizer.param_groups:\n",
    "                pg[\"lr\"] = lr\n",
    "\n",
    "            scaler.step(optimizer)\n",
    "            scaler.update()\n",
    "            optimizer.zero_grad(set_to_none=True)\n",
    "            global_step += 1\n",
    "\n",
    "            if global_step % cfg.log_interval == 0:\n",
    "                elapsed = time.time() - t0\n",
    "                tok_per_sec = cfg.batch_size * cfg.max_seq_len * cfg.log_interval / elapsed\n",
    "                print(f\"epoch {epoch+1} | step {global_step:,} | \"\n",
    "                      f\"loss {loss.item()*cfg.grad_accum:.4f} | \"\n",
    "                      f\"lr {lr:.2e} | {tok_per_sec/1000:.1f}k tok/s\")\n",
    "                t0 = time.time()\n",
    "\n",
    "            if global_step % cfg.eval_interval == 0:\n",
    "                val_loss = evaluate()\n",
    "                print(f\"  ── val loss: {val_loss:.4f} | perplexity: {math.exp(val_loss):.1f}\")\n",
    "\n",
    "            if global_step % cfg.save_interval == 0:\n",
    "                save_checkpoint(epoch, global_step)\n",
    "\n",
    "    # end of epoch\n",
    "    val_loss = evaluate()\n",
    "    print(f\"\\n=== Epoch {epoch+1} done | val loss {val_loss:.4f} | perplexity {math.exp(val_loss):.1f} ===\\n\")\n",
    "    save_checkpoint(epoch + 1, global_step)\n",
    "\n",
    "print(\"Training complete!\")"
   ]
  },
  {
   "cell_type": "markdown",
